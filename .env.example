# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Runtime
NODE_ENV="production"

# Public application origin used for auth redirects.
SELF_URL="http://localhost:8080"

# Authentication
# Google OAuth is handled by the myClawTeam auth service. Do not add Google
# client IDs or client secrets to this app.
MCTAI_AUTH_URL="https://auth.mctai.app"
MCTAI_AUTH_APP_TOKEN="app_token_from_myclawteam"
MCTAI_AUTH_JWKS_URL="https://auth.mctai.app/.well-known/jwks.json"

# Fixed admin password login
ADMIN_PASSWORD="replace-with-a-long-random-password"

# Object storage
# Use the vendor-neutral object storage names. The bucket is private, and the
# prefix must be prepended to every S3 object key by storage code. The prefix
# value should include its trailing slash.
OBJECT_STORAGE_ACCESS_KEY_ID="object-storage-access-key-id"
OBJECT_STORAGE_SECRET_ACCESS_KEY="object-storage-secret-access-key"
OBJECT_STORAGE_BUCKET="object-storage-bucket"
OBJECT_STORAGE_PREFIX="app_mike_t_4b46_ai_news_01_a92a65/"
OBJECT_STORAGE_ENDPOINT="https://fly.storage.tigris.dev"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_FORCE_PATH_STYLE="true"
